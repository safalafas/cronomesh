// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums
// Define user roles
enum Role {
  EMPLOYEE
  MANAGER
}

// Define types of employment
enum EmploymentType {
  FULL_TIME
  PART_TIME
  CASUAL
}

// Define schedule period types
enum PeriodType {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

// Define schedule statuses
enum ScheduleStatus {
  DRAFT
  PUBLISHED
}

// Models
// User model
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  details   EmployeeDetails?
  createdScheduleTemplates ScheduleTemplate[]
}

// EmployeeDetails model to store additional information about employees
model EmployeeDetails {
  id String @id @default(uuid())
  userId String @unique
  employmentType EmploymentType
  hourlyWage Float?
  desiredHoursPerWeek Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id])
  employeeLocations EmployeeLocation[]
  shiftAssignments ShiftAssignment[]
  availabilities EmployeeAvailability[]
}

// EmployeeAvailability model to store employee availability and preferences
model EmployeeAvailability {
  id String @id @default(uuid())
  employeeId String
  dayOfWeek Int
  isAvailable Boolean
  isPreferred Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employee EmployeeDetails @relation(fields: [employeeId], references: [id])
  @@unique([employeeId, dayOfWeek])
}

// Location model to represent different work locations
model Location {
  id String @id @default(uuid())
  name String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employeeLocations EmployeeLocation[]
  shiftTemplates ShiftTemplate[]
  shifts Shift[]
}

// Join table to represent the many-to-many relationship between employees and locations
model EmployeeLocation {
  id String @id @default(uuid())
  employeeId String
  locationId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employee EmployeeDetails @relation(fields: [employeeId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
  @@unique([employeeId, locationId])
}

// ScheduleTemplate model to define templates for schedules, which can be reused for creating actual schedules
model ScheduleTemplate {
  id String @id @default(uuid())
  name String
  periodType PeriodType
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdByUser User @relation(fields: [createdBy], references: [id])
  shiftTemplates ShiftTemplate[]
  schedules Schedule[]
}

// ShiftTemplate model to define templates for shifts, which can be reused for creating actual shifts
model ShiftTemplate {
  id String @id @default(uuid())
  scheduleTemplateId String
  locationId String
  name String
  dayOfWeek Int
  startTime Int
  endTime Int
  minEmployees Int
  maxEmployees Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  scheduleTemplate ScheduleTemplate @relation(fields: [scheduleTemplateId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
  servicePeriods ServicePeriod[]
  shifts Shift[]
}

// ServicePeriod model to define specific time periods for shifts
model ServicePeriod {
  id String @id @default(uuid())
  shiftTemplateId String
  name String
  startTime Int
  endTime Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shiftTemplate ShiftTemplate @relation(fields: [shiftTemplateId], references: [id])
}

// Schedule model to represent actual schedules created from templates
model Schedule {
  id String @id @default(uuid())
  scheduleTemplateId String
  startDate DateTime
  endDate DateTime
  status ScheduleStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  scheduleTemplate ScheduleTemplate @relation(fields: [scheduleTemplateId], references: [id])
  shifts Shift[]
}

// Shift model to represent actual shifts created from templates and assigned to schedules
model Shift {
  id String @id @default(uuid())
  scheduleId String
  shiftTemplateId String
  locationId String
  date DateTime
  startTime Int
  endTime Int
  minEmployees Int
  maxEmployees Int
  status ScheduleStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schedule Schedule @relation(fields: [scheduleId], references: [id])
  shiftTemplate ShiftTemplate @relation(fields: [shiftTemplateId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
  shiftAssignments ShiftAssignment[]
}

// ShiftAssignment model to represent the assignment of employees to shifts
model ShiftAssignment {
  id String @id @default(uuid())
  shiftId String
  employeeId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shift Shift @relation(fields: [shiftId], references: [id])
  employee EmployeeDetails @relation(fields: [employeeId], references: [id])
  @@unique([shiftId, employeeId])
}